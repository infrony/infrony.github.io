---
import '~/assets/styles/tailwind.css';

import { I18N } from 'astrowind:config';

import CommonMeta from '~/components/common/CommonMeta.astro';
import Favicons from '~/components/Favicons.astro';
import CustomStyles from '~/components/CustomStyles.astro';
import ApplyColorMode from '~/components/common/ApplyColorMode.astro';
import Metadata from '~/components/common/Metadata.astro';
import SiteVerification from '~/components/common/SiteVerification.astro';
import Analytics from '~/components/common/Analytics.astro';
import BasicScripts from '~/components/common/BasicScripts.astro';

import { Icon } from 'astro-icon/components';

import type { MetaData as MetaDataType } from '~/types';

export interface Props {
  metadata?: MetaDataType;
}

const { metadata = {} } = Astro.props;
const { language, textDirection } = I18N;
---

<!doctype html>
<html lang={language} dir={textDirection} class="2xl:text-[20px]">
  <head>
    <CommonMeta />
    <Favicons />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="anonymous" />
    <link
      href="https://fonts.googleapis.com/css2?family=Hammersmith+One&family=Open+Sans:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />
    <CustomStyles />
    <ApplyColorMode />
    <Metadata {...metadata} />
    <SiteVerification />
    <Analytics />

    <script is:inline type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "Organization",
        "name": "INFRONY SYSTEMS",
        "url": "https://infrony.com",
        "logo": "https://pub-f30bb22e4bb247bea2af2e1ef8376e00.r2.dev/logos/logo%20horizontal%20new.png",
        "description": "Empresa de ingenieria enfocada en automatizacion con IA, desarrollo de software e integracion de sistemas.",
        "sameAs": [
          "https://www.facebook.com/servitechinfrony",
          "https://www.instagram.com/servitech.infrony",
          "https://www.linkedin.com/company/servitechinfrony"
        ]
      }
    </script>

    <script>
      (function (w, d, s, l, i) {
        (w as unknown as { [key: string]: unknown })[l] = (w as unknown as { [key: string]: unknown })[l] || [];
        (w as unknown as { [key: string]: unknown[] })[l].push({ 'gtm.start': new Date().getTime(), event: 'gtm.js' });
        const f = d.getElementsByTagName(s)[0],
          j = d.createElement(s) as HTMLScriptElement,
          dl = l != 'dataLayer' ? '&l=' + l : '';
        (j as HTMLScriptElement).async = true;
        j.src = 'https://www.googletagmanager.com/gtm.js?id=' + i + dl;
        if (f && f.parentNode) {
          f.parentNode.insertBefore(j, f);
        }
      })(window, document, 'script', 'dataLayer', 'GTM-TZLKLV5Z');
    </script>
  </head>

  <body class="antialiased text-default bg-page tracking-tight">
    <noscript
      ><iframe
        src="https://www.googletagmanager.com/ns.html?id=GTM-TZLKLV5Z"
        height="0"
        width="0"
        style="display:none;visibility:hidden"></iframe></noscript
    >

    <slot />

    <a
      href="https://wa.me/message/NQ2M2DC3AEDZD1"
      target="_blank"
      class="sticky-btn"
      aria-label="Chateanos por WhatsApp"
    >
      <Icon name="tabler:brand-whatsapp" class="sticky-icon" />
    </a>

    <BasicScripts />
  </body>
</html>
