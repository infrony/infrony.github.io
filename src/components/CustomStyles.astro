---

<style is:inline>
  :root {
    --aw-font-sans: 'Open Sans', sans-serif;
    --aw-font-serif: 'Open Sans', sans-serif;
    --aw-font-heading: 'Open Sans', sans-serif;

    --aw-color-primary: #b2d731;
    --aw-color-secondary: #8fcb29;
    --aw-color-accent: #293542;

    --aw-color-text-heading: #293542;
    --aw-color-text-default: #293542;
    --aw-color-text-muted: #a6a6a6;
    --aw-color-bg-page: #fefffd;
    --aw-color-bg-page-dark: #293542;

    ::selection {
      background-color: #b2d731;
      color: #293542;
    }
  }

  .dark {
    --aw-font-sans: 'Open Sans', sans-serif;
    --aw-font-serif: 'Open Sans', sans-serif;
    --aw-font-heading: 'Open Sans', sans-serif;

    --aw-color-primary: #b2d731;
    --aw-color-secondary: #8fcb29;
    --aw-color-accent: #293542;

    --aw-color-text-heading: #fefffd;
    --aw-color-text-default: #fefffd;
    --aw-color-text-muted: #a6a6a6;
    --aw-color-bg-page: #0e1116;

    ::selection {
      background-color: #b2d731;
      color: #293542;
    }
  }

  .sticky-btn {
    position: fixed;
    bottom: 20px;
    right: 20px;
    background-color: #25d366;
    border-radius: 50%;
    width: 60px;
    height: 60px;
    box-shadow: 0 4px 8px rgba(0, 0, 0, 0.2);
    display: flex;
    justify-content: center;
    align-items: center;
    z-index: 1000;
    transition: background-color 0.3s ease-in-out;
  }

  .sticky-btn:hover {
    background-color: #128c7e;
  }

  .sticky-icon {
    width: 35px;
    height: 35px;
    color: #ffffff;
  }

  @media screen and (max-width: 768px) {
    .sticky-btn {
      bottom: 15px;
      right: 15px;
      width: 50px;
      height: 50px;
    }

    .sticky-icon {
      width: 30px;
      height: 30px;
    }
  }
</style>
